<style>
      /* Danh mục nổi bật */
    .featured-categories {
        background-color: #f2f5ff;
        padding: 20px;
        border-radius: 10px;
        max-width: 1200px;
        margin: auto;
        text-align: center;
    }

        .featured-categories h3 {
            font-size: 25px;
            font-weight: bold;
            color: #1a73e8;
            margin-right: 800px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); /* Chia cột tự động */
        gap: 15px;
        justify-items: center;
        margin-top: 15px;
    }

    .category-item {
        background-color: white;
        border-radius: 12px;
        padding: 15px;
        text-align: center;
        font-weight: bold;
        box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
        width: 180px;
    }

        .category-item:hover {
            transform: translateY(-5px);
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15);
        }

        .category-item img {
            width: 40px;
            height: 40px;
            margin-bottom: 10px;
        }

        .category-item h4 {
            font-size: 16px;
            color: #1a73e8;
            margin-bottom: 5px;
        }

        .category-item p {
            font-size: 14px;
            color: #666;
        }

        /* Chuyên gia bác sĩ */
.expert-section {
    background: linear-gradient(to right, #2563eb, #4f8ef7);
    color: white;
    text-align: center;
    padding: 25px;
    border-radius: 12px;
    width: 1200px;
    margin-right: 400px;
    
}

/* Danh sách chuyên gia */
.expert-list {
    display: flex;
    justify-content: center;
    flex-wrap: wrap; /* Giúp không bị bể khi màn hình nhỏ */
    gap: 20px;
    margin-top: 20px;
}

/* Thẻ chuyên gia */
.expert-card {
    background-color: white;
    color: black;
    padding: 15px;
    border-radius: 10px;
    width: 280px;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s;
    margin: 10px;
}

/* Hiệu ứng hover */
.expert-card:hover {
    transform: scale(1.05);
}

/* Hình ảnh bác sĩ */
.expert-card img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    margin-right: 15px;
}

/* Thông tin chuyên gia */
.expert-info h3 {
    margin: 0;
    font-size: 18px;
}

.expert-info p {
    font-size: 14px;
    color: #555;
}

/* Nút tìm hiểu thêm */
.btn-learn-more {
    background-color: #FFFFFF;
    color: black;
    border: none;
    padding: 12px 24px;
    border-radius: 30px;
    font-size: 16px;
    cursor: pointer;
    transition: background 0.3s ease;
    margin-top: 15px;
}

.btn-learn-more:hover {
    background-color: #e6b800;
}


    
