@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Thống Kê Doanh Thu Theo Ngày";
}

<h1>@ViewData["Title"]</h1>

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning">
        @ViewBag.Message
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Ngày</th>
                <th>Doanh Thu</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <a href="@Url.Action("DonHangTheoNgay", "DonHangs", new { nam = item.Nam, thang = item.Thang, ngay = item.Ngay })">
                            Ngày @item.Ngay
                        </a>
                    </td>
                    <td>@string.Format("{0:n0}", item.DoanhThu) VNĐ</td>
                </tr>
            }
        </tbody>
    </table>
}
