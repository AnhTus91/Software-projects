":1,"measureUnitName":"Hộp","isSellDefault":true,"price":95000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"discount":{"discountPrice":19000,"finalPrice":76000,"itemCode":"00040432","unitCode":1,"maxValue":0,"price":95000,"promotionTags":[{"promotionTitle":"-20%","promotionType":2,"promotionCode":"KM-0225-143","isFlashSale":false}]}},"specification":"Hộp"},{"category":[{"id":4,"name":"Chăm sóc cá nhân","parentName":null,"level":1,"slug":"cham-soc-ca-nhan","isActive":true,"searchScoring":0},{"id":58,"name":"Đồ dùng gia đình","parentName":"Chăm sóc cá nhân","level":2,"slug":"cham-soc-ca-nhan/do-dung-gia-dinh","isActive":true,"searchScoring":0},{"id":494,"name":"Đồ dùng cho bé","parentName":"Đồ dùng gia đình","level":3,"slug":"cham-soc-ca-nhan/do-dung-cho-be","isActive":true,"searchScoring":0}],"shortDescription":"\u003cp\u003eTinh dầu chuyên dụng cho bé sơ sinh Thảo Nguyên giúp phòng ngừa cảm lạnh, phòng gió, làm ấm phổi, long đờm, giảm ho, bụng đầy hơi, khó tiêu. Kích thích tuần hoàn máu, lưu thông khí huyết. Ngăn ngừa bệnh lây qua đường hô hấp và bệnh ngoài da, giảm ngứa. Giữ ẩm cho da, chống khô da, rôm sảy, lác sữa. Chống muỗi và côn trùng đốt, làm dịu các vết đốt do muỗi và côn trùng gây ra.\u003c/p\u003e","isPublish":true,"prices":[{"id":67904,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":true,"price":119000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":1,"productSpecs":null,"discount":{"discountPrice":35700,"finalPrice":83300,"itemCode":"00044228","unitCode":1,"maxValue":0,"price":119000,"promotionTags":[{"promotionTitle":"-30%","promotionType":2,"promotionCode":"KM-0225-141","isFlashSale":false}]}}],"sku":"00044228","webName":"Tinh dầu cho bé sơ sinh Thảo Nguyên giúp phòng ngừa cảm lạnh, phòng gió, làm ấm phổi (50ml)","name":"TINH DẦU CHO BÉ SƠ SINH THẢO NGUYÊN 50ML","image":"https://cdn.nhathuoclongchau.com.vn/unsafe/https://cms-prod.s3-sgn09.fptcloud.com/DSC_02974_ff6ee7e49e.jpg","slug":"cham-soc-ca-nhan/tinh-dau-cho-be-so-sinh-thao-nguyen-50-ml.html","brand":"Thảo Nguyên","productRanking":0,"displayCode":1,"price":{"id":67904,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":true,"price":119000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"discount":{"discountPrice":35700,"finalPrice":83300,"itemCode":"00044228","unitCode":1,"maxValue":0,"price":119000,"promotionTags":[{"promotionTitle":"-30%","promotionType":2,"promotionCode":"KM-0225-141","isFlashSale":false}]}},"specification":"Hộp"},{"category":[{"id":5,"name":"Thực phẩm chức năng","parentName":null,"level":1,"slug":"thuc-pham-chuc-nang","isActive":true,"searchScoring":0},{"id":67,"name":"Cải thiện tăng cường chức năng","parentName":"Thực phẩm chức năng","level":2,"slug":"thuc-pham-chuc-nang/cai-thien-tang-cuong-chuc-nang","isActive":true,"searchScoring":0},{"id":519,"name":"Tăng sức đề kháng, miễn dịch","parentName":"Cải thiện tăng cường chức năng","level":3,"slug":"thuc-pham-chuc-nang/ho-tro-mien-dich-tang-suc-de-khang","isActive":true,"searchScoring":0}],"shortDescription":"\u003cp\u003eBổ Phế Lábebé hỗ trợ bổ phế, giúp giảm ho, giảm đờm, giảm đau họng, khản tiếng do viêm họng, viêm phế quản.\u003c/p\u003e","isPublish":true,"prices":[{"id":72207,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":true,"price":75000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":1,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":75000,"itemCode":"00046430","unitCode":1,"maxValue":0,"price":75000,"promotionTags":[]}}],"sku":"00046430","webName":"Siro Bổ Phế Lábebé 120ml hỗ trợ bổ phế, giảm ho, giảm đờm, giảm đau họng","name":"SIRO HO, BỔ PHẾ LÁBEBÉ 120ML","image":"https://cdn.nhathuoclongchau.com.vn/unsafe/https://cms-prod.s3-sgn09.fptcloud.com/DSC_09352_ae155b3fe6.jpg","slug":"thuc-pham-chuc-nang/siro-giup-giam-ho-bo-phe-labebe-120-ml.html","brand":"LÁBEBÉ","productRanking":0,"displayCode":1,"price":{"id":72207,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":tr