ham-chuc-nang/kem-magie","isActive":true,"searchScoring":0}],"shortDescription":"\u003cp\u003eDHC Zinc bổ sung kẽm cho cơ thể, hỗ trợ duy trì sức khỏe, giúp cơ thể khỏe mạnh.\u003c/p\u003e","isPublish":true,"prices":[{"id":50799,"measureUnitCode":14,"measureUnitName":"Gói","isSellDefault":true,"price":100000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":1,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":100000,"itemCode":"00501635","unitCode":14,"maxValue":0,"price":100000,"promotionTags":[]}}],"sku":"00501635","webName":"Viên uống DHC Zinc bổ sung kẽm cho cơ thể, hỗ trợ duy trì sức khỏe (30 viên)","name":"DHC ZINC 30V","image":"https://cdn.nhathuoclongchau.com.vn/unsafe/https://cms-prod.s3-sgn09.fptcloud.com/00501635_dhc_zinc_30v_5817_62fb_large_7d724d9b77.jpg","slug":"thuc-pham-chuc-nang/dhc-zinc-30v-35783.html","brand":"DHC","productRanking":0,"displayCode":1,"price":{"id":50799,"measureUnitCode":14,"measureUnitName":"Gói","isSellDefault":true,"price":100000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"discount":{"discountPrice":0,"finalPrice":100000,"itemCode":"00501635","unitCode":14,"maxValue":0,"price":100000,"promotionTags":[]}},"specification":"Gói 30 Viên","promotionTags":[]},{"category":[{"id":1,"name":"Thuốc","parentName":null,"level":1,"slug":"thuoc","isActive":true,"searchScoring":0},{"id":736,"name":"Thuốc tiêu hoá \u0026 gan mật","parentName":"Thuốc","level":2,"slug":"thuoc/thuoc-tieu-hoa-and-gan-mat","isActive":true,"searchScoring":0},{"id":807,"name":"Thuốc tiêu hoá","parentName":"Thuốc tiêu hoá \u0026 gan mật","level":3,"slug":"thuoc/thuoc-tieu-hoa-and-gan-mat/thuoc-tieu-hoa","isActive":true,"searchScoring":0}],"shortDescription":"\u003cp style=\"text-align:justify;\"\u003eEnterogermina là sản phẩm của nhà sản xuất Sanofi (Italia), có thành phần chính bào tử kháng đa kháng sinh Bacillus clausii.\u003c/p\u003e\u003cp style=\"text-align:justify;\"\u003eThuốc được dùng để điều trị và phòng ngừa rối loạn hệ vi khuẩn đường ruột và bệnh lý kém hấp thu vitamin nội sinh, điều trị hỗ trợ để phục hồi hệ vi khuẩn đường ruột bị ảnh hưởng khi dùng thuốc kháng sinh hoặc hóa trị liệu, rối loạn tiêu hóa cấp và mạn tính ở trẻ em do nhiễm độc hoặc rối loạn hệ vi khuẩn\u0026nbsp;đường ruột và kém hấp thu vitamin.\u003c/p\u003e","isPublish":true,"prices":[{"id":3736,"measureUnitCode":13,"measureUnitName":"Vỉ","isSellDefault":false,"price":80750,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":2,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":80750,"itemCode":"00002814","unitCode":13,"maxValue":0,"price":80750,"promotionTags":[]}},{"id":3737,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":true,"price":161500,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":1,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":161500,"itemCode":"00002814","unitCode":1,"maxValue":0,"price":161500,"promotionTags":[]}},{"id":3735,"measureUnitCode":15,"measureUnitName":"Ống","isSellDefault":false,"price":8075,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":3,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":8075,"itemCode":"00002814","unitCode":15,"maxValue":0,"price":8075,"promotionTags":[]}}],"sku":"00002814","webName":"Hỗn dịch uống men vi sinh Enterogermina 2 tỷ/5ml điều trị rối loạn tiêu hóa (2 vỉ x 10 ống)","name":"ENTEROGERMINA 2 TỶ SANOFI 2X10 5ML","image":"https://cdn.nhathuoclongchau.com.vn/unsafe/https://cms-prod.s3-sgn09.fptcloud.com/00002814_enterogemina_5ml_sanofi_20_ong_5650_60fb_large_25c7916c1f.jpg","slug":"thuoc/enterogemina-5ml-sanofi-20-ong-17315.html","brand":"Sanofi","productRanking":0,"displayCode":1,"price":{"id":3737,"measureUnitCode":1,"measureUnitName":"Hộp","isSellDefault":true,"price":161500,"currencySymbol":"đ","isDefault":true,"isInventory":true,"discount":{"discountPrice":0,"finalPrice":80750,"itemCode":"00002814","unitCode":13,"maxValue":0,"price":80750,"promotionTags":[]}},