28","unitCode":2,"maxValue":0,"price":99000,"promotionTags":[]}},"specification":"Tuýp","promotionTags":[]},{"category":[{"id":2,"name":"Dược mỹ phẩm","parentName":null,"level":1,"slug":"duoc-my-pham","isActive":true,"searchScoring":0},{"id":52,"name":"Giải pháp làn da","parentName":"Dược mỹ phẩm","level":2,"slug":"duoc-my-pham/giai-phap-lan-da","isActive":true,"searchScoring":0},{"id":476,"name":"Kem trị mụn, gel trị mụn","parentName":"Giải pháp làn da","level":3,"slug":"duoc-my-pham/da-mun","isActive":true,"searchScoring":0}],"shortDescription":"\u003cp\u003eMegaduo Gel giúp dưỡng da, ngừa mụn trứng cá và ngừa sẹo thâm do mụn để lại. Megaduo là dòng sản phẩm đặc trị mụn được bác sĩ da liễu khuyên dùng và nhận được phản hồi tích cực từ nhiều người sử dụng.\u003c/p\u003e","isPublish":true,"prices":[{"id":12565,"measureUnitCode":2,"measureUnitName":"Tuýp","isSellDefault":true,"price":125000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"level":1,"productSpecs":null,"discount":{"discountPrice":0,"finalPrice":125000,"itemCode":"00008523","unitCode":2,"maxValue":0,"price":125000,"promotionTags":[]}}],"sku":"00008523","webName":"Gel Megaduo hỗ trợ ngừa mụn trứng cá, ngừa thâm, dưỡng da (15g)","name":"GEL HỖ TRỢ ĐIỀU TRỊ MỤN VÀ VẾT THÂM - MEGADUO GEL GAMMA 15G","image":"https://cdn.nhathuoclongchau.com.vn/unsafe/https://cms-prod.s3-sgn09.fptcloud.com/00008523_megaduo_gel_15g_3722_62ae_large_18ab1ee430.JPG","slug":"duoc-my-pham/megaduo-gel-15g-16664.html","brand":"GAMMA","productRanking":0,"displayCode":1,"price":{"id":12565,"measureUnitCode":2,"measureUnitName":"Tuýp","isSellDefault":true,"price":125000,"currencySymbol":"đ","isDefault":true,"isInventory":true,"discount":{"discountPrice":0,"finalPrice":125000,"itemCode":"00008523","unitCode":2,"maxValue":0,"price":125000,"promotionTags":[]}},"specification":"Tuýp","promotionTags":[]},{"category":[{"id":5,"name":"Thực phẩm chức năng","parentName":null,"level":1,"slug":"thuc-pham-chuc-nang","isActive":true,"search